{
  "name": "ens-registry-diagram",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "npm run lib:build && tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lib:build": "npm run build -w @ensdomains/osse",
    "lib:pack": "npm run lib:build && npm pack -w @ensdomains/osse",
    "devrel:revisit": "node scripts/devrel-revisit.mjs"
  },
  "dependencies": {
    "@ensdomains/osse": "*",
    "dialkit": "^1.3.0",
    "marked": "^18.0.6",
    "motion": "^11",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "typescript": "^5",
    "vite": "^5",
    "vitest": "^4.1.8"
  }
}
